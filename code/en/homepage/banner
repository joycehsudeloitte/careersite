      justify-content: center !important; align-items: center !important; z-index: 9999 !important;
      backdrop-filter: blur(8px) !important;
    }

    .modal-content {
      background: white !important; width: 90% !important; max-width: 850px !important;
      padding: 45px !important; border-radius: 4px !important; position: relative !important;
      max-height: 90vh !important; overflow-y: auto !important;
    }

    .modal-header { border-bottom: 3px solid #86BC25 !important; margin-bottom: 25px !important; padding-bottom: 10px !important; }
    .modal-header h3 { margin: 0 !important; font-size: 24px !important; color: #000 !important; }

    /* 2-Column Grid for Modals */
    html body .modal-grid { 
      display: grid !important; 
      grid-template-columns: 1fr 1fr !important; 
      gap: 15px !important; 
      margin-top: 20px !important; 
    }

    html body .modal-item {
      padding: 20px !important; border: 1px solid #eee !important; text-decoration: none !important; color: #333 !important;
      border-left: 6px solid #ccc !important; transition: 0.2s !important;
      display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important;
      min-height: 80px !important; font-weight: bold !important;
    }
    .modal-item:hover { background: #f9fff0 !important; border-color: #86BC25 !important; }

    html body .view-all-btn {
      display: block !important; width: 100% !important; text-align: center !important; margin-top: 30px !important;
      padding: 15px !important; background-color: #000 !important; color: #ffffff !important; 
      text-decoration: none !important; font-weight: bold !important;
    }

    /* --- Responsive Mobile Settings --- */
    @media (max-width: 768px) {
      .banner-desktop-img { display: none !important; }
      .banner-mobile-img { display: block !important; }
      
      .entry-container { 
        margin: 20px auto 0 auto !important; 
        flex-direction: column !important;
        flex-wrap: wrap !important;
      }
      
      .entry-card { width: 100% !important; min-width: 100% !important; }

      html body .modal-grid { grid-template-columns: 1fr !important; }
    }
  </style>

  <script>
    function openModal(id) {
      document.getElementById(id).style.setProperty('display', 'flex', 'important');
      document.body.style.overflow = 'hidden';
    }
    function closeModal(id) {
      document.getElementById(id).style.setProperty('display', 'none', 'important');
      document.body.style.overflow = 'auto';
    }
    window.onclick = function(e) {
      if (e.target.className === 'modal-overlay') {
        e.target.style.setProperty('display', 'none', 'important');
        document.body.style.overflow = 'auto';
      }
    }
  </script>
</section>

