.ldc-notice-email { color: #86BC25; text-decoration: none; font-weight: 600; }

/* 底部投遞按鈕 */
.ldc-btn-container { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 20px; }
a.ldc-apply-btn, a.ldc-apply-btn:link, a.ldc-apply-btn:visited {
