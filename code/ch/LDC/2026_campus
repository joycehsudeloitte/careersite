a.btn-taipei { border-color: #86BC25 !important; color: #86BC25 !important; }
a.btn-taipei:hover { background-color: #86BC25 !important; color: #fff !important; }
a.btn-taichung { border-color: #43B02A !important; color: #43B02A !important; }
a.btn-taichung:hover { background-color: #43B02A !important; color: #fff !important; }
a.btn-kaohsiung { border-color: #26890D !important; color: #26890D !important; }
a.btn-kaohsiung:hover { background-color: #26890D !important; color: #fff !important; }

@media (max-width: 900px) {
