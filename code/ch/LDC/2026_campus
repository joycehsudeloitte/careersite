<script>
/* --- 下拉選單切換邏輯 --- */
function toggleDropdown(id) {
    const allDropdowns = document.querySelectorAll('.ldc-dropdown-content');
    allDropdowns.forEach(dropdown => {
        if (dropdown.id !== id) {
            dropdown.classList.remove('show');
        }
    });
    document.getElementById(id).classList.toggle("show");
}

window.onclick = function(event) {
    if (!event.target.matches('.ldc-card-apply-btn')) {
        const dropdowns = document.querySelectorAll('.ldc-dropdown-content');
        dropdowns.forEach(dropdown => {
            if (dropdown.classList.contains('show')) {
                dropdown.classList.remove('show');
            }
        });
    }
}

/* --- 活動過期自動檢查 --- */
document.addEventListener('DOMContentLoaded', function() {
    const events = document.querySelectorAll('.ldc-event-item');
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    events.forEach(event => {
        const eventDateStr = event.getAttribute('data-date');
        if (eventDateStr) {
            const eventDate = new Date(eventDateStr);
            if (today > eventDate) {
                event.classList.add('event-item-ended');
                const btn = event.querySelector('.ldc-reg-btn');
                if (btn) {
                    btn.textContent = '已結束';
                    btn.setAttribute('href', 'javascript:void(0)');
                }
            }
        }
    });
});
</script>
