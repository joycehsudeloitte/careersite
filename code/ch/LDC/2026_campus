}

.ldc-intern-title {
  font-size: 42px;
  font-weight: 800;
  line-height: 1.3;
  color: #000000;
  margin: 0;
}

.ldc-intern-content {
  font-size: 18px;
  line-height: 1.8;
  color: #333333;
  margin-bottom: 16px;
}

.ldc-intern-highlight {
  font-size: 20px;
  font-weight: 600;
  color: #86BC25;
  margin-top: 24px;
  margin-bottom: 12px;
}

.highlights { list-style: none; padding-left: 0; margin: 0; }
.highlights li {
  margin-bottom: 12px;
  position: relative;
  padding-left: 20px;
  line-height: 1.7;
  display: block;
  color: #333333;
}
.highlights li::before {
  content: "•";
  position: absolute; left: 0; top: 4px;
  font-size: 20px; color: #86BC25;
}
.highlights li span { font-weight: 700; }

/* =========================================
   3. 圖片樣式
========================================= */
.ldc-intern-image-box { flex: 1; text-align: left; }
.ldc-intern-image-box img {
  width: 100%; max-width: 550px;
  border-radius: 12px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}

/* =========================================
   4. 下方資訊區塊 (Timeline / Events / Req)
========================================= */
.ldc-intern-bottom {
  width: 90%;
  max-width: 1400px;
  margin: 60px auto 0;
  display: flex;
  flex-direction: column;
  gap: 40px;
}

/* 招募時程圓圈 */
.ldc-intern-timeline-wrapper { position: relative; padding: 20px 0; }
.ldc-intern-timeline-line {
  position: absolute; top: 70px; left: 0; right: 0; height: 2px; background: #d9d9d9; z-index: 1;
}
.ldc-intern-timeline-items { display: flex; justify-content: space-between; position: relative; z-index: 2; }
.ldc-intern-timeline-item { text-align: center; flex: 1; }
.ldc-intern-timeline-circle {
  width: 100px; height: 100px; margin: 0 auto 15px;
  border-radius: 50%; border: 3px solid #86BC25; background: #ffffff;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 20px; color: #000000;
}

/* Grid 佈局達成標題水平對齊 */
.ldc-events-section {  
  display: grid;  
  grid-template-columns: 1fr 1fr;  
  grid-template-rows: auto 1fr;  
  gap: 0 48px;  
  align-items: start;
}

.ldc-section-title {
  font-size: 22px;
  font-weight: 700;
  color: #333;
  margin-bottom: 20px;
  padding-left: 12px;
  border-left: 6px solid #86BC25;
  line-height: 1.2;
}

.title-events { grid-column: 1; grid-row: 1; }
.title-req { grid-column: 2; grid-row: 1; }

.ldc-events-box {  
  grid-column: 1; grid-row: 2;  
  background: #ffffff; padding: 25px; border-radius: 12px;
  box-shadow: 0 2px 15px rgba(0,0,0,0.05);
}
.ldc-intern-req-box { grid-column: 2; grid-row: 2; }

/* 活動列表項目 */
.ldc-event-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}
.ldc-event-item:last-child { border-bottom: none; }
.ldc-event-school { font-size: 16px; font-weight: 700; color: #000; display: block; margin-bottom: 2px; }
.ldc-event-date { font-size: 13px; color: #666; }

/* 立即報名按鈕樣式 */
.ldc-reg-btn {
  padding: 6px 16px;
  border: 2px solid #86BC25 !important;
  background-color: transparent !important;
  color: #86BC25 !important;
  text-decoration: none !important;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 700;
  transition: all 0.3s ease;
  white-space: nowrap;
}
.ldc-reg-btn:hover {
  background-color: #000000 !important;
  border-color: #000000 !important;
  color: #ffffff !important;
}

.event-item-ended { opacity: 0.5; }
.event-item-ended .ldc-reg-btn {
  border-color: #ccc !important;
  color: #999 !important;
  pointer-events: none;
  background: #f5f5f5 !important;
}

/* 應徵小提醒樣式 */
.ldc-notice-box {
